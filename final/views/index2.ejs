<html>
  <head>
    <title>to someone you miss ~</title>
    <link href="style.css" rel="stylesheet" />
    <script src="main.js"></script>
    <link rel="stylesheet" href="https://use.typekit.net/zeu5kpj.css" />
  </head>
  <body>
    <div class="page">
      <div class="spine-line"></div>
      <div class="left-page">
      <form action="/submit" method="POST" class="full-form">
          <h2>message you would like to send them:</h2>
          <textarea name="message" required></textarea>
        </div>

        <div class="right-page">
          <h2>your name?</h2>
          <input type="text" name="senderName" placeholder="input your name" required />
        </div>

        <div class="bottom">
          <div id="liveTime"></div>
          <button type="submit" class="arrow-button">-----> 💌</button>
        </div>
      </form>
    </div>
  </body>
</html>
