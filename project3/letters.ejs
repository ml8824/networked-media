<html>
    <head>
        <title> 💌 </title>
        <link href="style.css" rel="stylesheet" />
        <script src="main.js"></script>
        <link rel="stylesheet" href="https://use.typekit.net/ela1xrn.css">
    </head>
    <body>
        <div id='date'></div>
        <div id='name'></div>
        <div id="content">
           <% for(let l of allLetters) { %>
